<section class="scroll-wrapper">

  <div class="panel">
    <h2>Section 1 — Product Intro</h2>
  </div>

  <div class="panel">
    <h2>Section 2 — Features</h2>
  </div>

  <div class="panel">
    <h2>Section 3 — Benefits</h2>
  </div>

  <img src="https://dummyimage.com/200x400/000/ffffff&text=Bottle" class="bottle" />

</section>

<style>
.scroll-wrapper {
  position: relative;
  overflow: visible;
}

/* Panels */
.panel {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42px;
  padding: 20px;
}

.panel h2 {
  max-width: 600px;
  text-align: center;
}

.panel:nth-child(1) { background: #f5f5f5; }
.panel:nth-child(2) { background: #eaeaea; }
.panel:nth-child(3) { background: #dddddd; }

/* Bottle */
.bottle {
  position: fixed;
  top: 50%;
  left: 0;
  transform: translate(-0%, -50%); /* ✅ IMPORTANT */

  width: 220px;
  z-index: 99999;
  pointer-events: none;
  opacity: 0; /* revealed after loader */

  /* depth */
  box-shadow: 0 20px 40px rgba(0,0,0,0.2);
}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
  if (typeof gsap === "undefined") return;

  gsap.registerPlugin(ScrollTrigger);

  // Horizontal travel tied to scroll
  gsap.to(".bottle", {
    x: () => window.innerWidth - 350,
    rotate: 8,
    scale: 1.05,
    ease: "none",
    scrollTrigger: {
      trigger: ".scroll-wrapper",
      start: "top top",
      end: "bottom bottom",
      scrub: 2
    }
  });

  // Subtle section reveal
  gsap.utils.toArray(".panel").forEach((panel) => {
    gsap.from(panel, {
      opacity: 0,
      y: 50,
      scrollTrigger: {
        trigger: panel,
        start: "top 80%",
        end: "top 50%",
        scrub: true
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "Scroll Bottle",
  "settings": [],
  "presets": [
    { "name": "Scroll Bottle" }
  ]
}
{% endschema %}